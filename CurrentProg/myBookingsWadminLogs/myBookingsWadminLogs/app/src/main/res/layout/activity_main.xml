<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    tools:context=".myBookings.MainActivity">


    <TextView
        android:layout_below="@id/bookingbtn"
        android:id="@+id/username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:text="User@chat.com"
        />

    <TextView
        android:id="@+id/confirm_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:text="Confirmed!"
        />

    <TextView
        android:layout_marginStart="5dp"
        android:id="@+id/confirm_txt2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:text="Organisation"
        android:layout_toRightOf="@id/confirm_txt"
        />

    <TextView
        android:layout_below="@id/confirm_txt"
        android:id="@+id/DynamicConfirmTxt"
        android:text="BookingORDonation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:text="booking"
        android:layout_below="@id/DynamicConfirmTxt"
        android:id="@+id/bookingbtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:layout_marginStart="5dp"
        android:text="dono"
        android:layout_below="@id/DynamicConfirmTxt"
        android:layout_toRightOf="@id/bookingbtn"
        android:id="@+id/donobtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</RelativeLayout>