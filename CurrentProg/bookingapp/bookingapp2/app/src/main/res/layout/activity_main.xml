<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A1EEBD"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Organization Spinner -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Select an Organization:"
        android:textColor="#333333"
        android:textSize="18sp" />

    <Spinner
        android:id="@+id/organizationSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:autofillHints="click to select"
        android:background="#F6D6D6"
        android:padding="8dp" />

    <!-- Select Date -->
    <Button
        android:id="@+id/selectDateButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#F6F7C4"
        android:text="Select Date"
        android:textColor="@color/black" />

    <!-- Selected Date Display -->
    <TextView
        android:id="@+id/selectedDateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#F6D6D6"
        android:text="Date: None"
        android:textColor="#444444"
        android:textSize="16sp" />

    <!-- Proceed Button -->
    <Button
        android:id="@+id/proceedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#F6F7C4"
        android:text="Proceed"
        android:textColor="@color/black" />
</LinearLayout>
