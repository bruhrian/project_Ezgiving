<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="10dp">

    <ImageView
        android:id="@+id/organisationImage"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/willinghearts" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical">

        <TextView
            android:id="@+id/organisationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name" />

        <TextView
            android:id="@+id/organisationAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address"
            />

        <!-- New LinearLayout for Address and Telephone side by side -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/organisationTel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telephone"
                />
            <TextView
                android:id="@+id/organisationDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                />
            <TextView
                android:id="@+id/orgTaskAct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Task/Activity"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
