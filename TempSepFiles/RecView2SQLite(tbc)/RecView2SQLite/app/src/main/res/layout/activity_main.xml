<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:gravity="center"
    >

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Organisation:"
        android:gravity="center"
        android:textSize="30sp"/>
    <TableLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TableRow>
            <TextView
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organisation Name: "
                android:layout_marginEnd="10dp"
                android:textSize="20dp"/>
            <EditText
                android:id="@+id/organisationNameET"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Organisation Name"
                android:minHeight="48dp"
                android:maxLines="1"/>
        </TableRow>
        <TableRow>
            <TextView
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organisation Address: "
                android:layout_marginEnd="10dp"
                android:textSize="20dp"/>
            <EditText
                android:id="@+id/organisationAddressET"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Organisation Address"
                android:minHeight="48dp"
                android:maxLines="1"/>
        </TableRow>
        <TableRow>
            <TextView
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organisation Tel: "
                android:layout_marginEnd="10dp"
                android:textSize="20dp"/>
            <EditText
                android:id="@+id/organisationTelET"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Organisation Tele"
                android:minHeight="48dp"/>
        </TableRow>
        <TableRow>
            <TextView
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organisation Activity: "
                android:layout_marginEnd="10dp"
                android:textSize="20dp"/>
            <EditText
                android:id="@+id/organisationActET"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Organisation Tele"
                android:minHeight="48dp"/>
        </TableRow>
        <TableRow>
            <TextView
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organisation Desc: "
                android:layout_marginEnd="10dp"
                android:textSize="20dp"/>
            <EditText
                android:id="@+id/organisationDescET"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Organisation Desc"
                android:minHeight="48dp"/>
        </TableRow>
        <TableRow>
            <TextView
                android:layout_marginStart="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Organisation Image:"
                android:textSize="20dp"/>

            <Button

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/select_image_button"
                android:text="select image"/>
        </TableRow>
    </TableLayout>



    <Button
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/upload_image_button"
        android:text="Upload info into DB"
        android:layout_gravity="center"/>

</LinearLayout>