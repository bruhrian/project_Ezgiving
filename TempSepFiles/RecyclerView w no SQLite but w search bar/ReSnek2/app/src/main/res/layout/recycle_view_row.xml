<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/paleYellow"
        app:cardCornerRadius="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="5dp"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/orgPic"
                android:layout_marginStart="20dp"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/communitychest"
                android:background="@android:color/transparent"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/OrganisationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@array/organisation_names"
                    android:textStyle="bold"
                    android:padding="10dp"
                    android:textSize="28sp"
                    android:textColor="@color/priOrange"/>
                <TextView
                    android:layout_marginStart="10dp"
                    android:id="@+id/taskORactivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@array/type_of_activity"
                    android:padding="6dp"
                    android:textSize="18sp"
                    android:textColor="@color/priOrange"
                    />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>